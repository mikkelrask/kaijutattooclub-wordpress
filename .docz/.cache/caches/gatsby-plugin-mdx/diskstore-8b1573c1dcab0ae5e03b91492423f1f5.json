s,\n  ...props\n}) {\n  return <MDXLayout {...layoutProps} {...props} components={components} mdxType=\"MDXLayout\">\n\n\n    <h1 {...{\n      \"id\": \"hvad-er-en-tatovør\"\n    }}>{`Hvad er en \"Tatovør\"?`}</h1>\n    <p>{`Ift hjemmesiden, er en `}<strong parentName=\"p\">{`tatovør`}</strong>{` en person der er del af Kaiju teamet, og har en `}<strong parentName=\"p\">{`profil`}</strong>{` på hjemmesiden. `}</p>\n    <p>{`På forsiden har vi vist aktive tatovører vist i `}<strong parentName=\"p\">{`Om Kaiju Tattoo Club`}</strong>{` sektionen, ligesom de er vist på `}<strong parentName=\"p\"><a parentName=\"strong\" {...{\n          \"href\": \"https://kaijutattooclub.dk/om-kaiju-tattoo-club\"\n        }}>{`Om Os`}</a></strong>{`-siden og har hver sin egen `}<strong parentName=\"p\">{`underside`}</strong>{` med instagram galleri og muligheder for at tilføje ekstra gallerier eks. til `}<strong parentName=\"p\">{`Wanna-do's`}</strong>{`, `}<strong parentName=\"p\">{`Flashs`}</strong>{` til næste event og meget mere.`}</p>\n    <p><img alt=\"Tatov\\xF8rer p\\xE5 forsiden af KaijuTattooClub.dk\" src={require(\"./tatovor.png\")} /></p>\n    <h2 {...{\n      \"id\": \"custom-tattoo-artist-\"\n    }}>{`Custom tattoo artist 😎`}</h2>\n    <p>{`Med andre ord, er det en nem måde at tilføje og håndtere information om den enkelte ansatte/tilknyttede tatovør.`}</p>\n    <p>{`Uden at det skal blive for teknisk, er en `}<strong parentName=\"p\">{`Wordpress Tatovør`}</strong>{` en special lavet `}<strong parentName=\"p\">{`post-type`}</strong>{` ligesom et blogindlæg er en `}<strong parentName=\"p\">{`post-type`}</strong>{` - men i stedet for at have en `}<strong parentName=\"p\">{`indlægs-titel`}</strong>{` og almindeligt tekstindhold, har `}<strong parentName=\"p\">{`tatovør-post-typen`}</strong>{` passende felter til fx `}<strong parentName=\"p\">{`fornavn`}</strong>{`, `}<strong parentName=\"p\">{`favorit-stilarter`}</strong>{`, `}<strong parentName=\"p\">{`Instagram brugernavn`}</strong>{`, `}<strong parentName=\"p\">{`e-mail`}</strong>{` osv - og med nem mulighed for at selv tilføje flere \"bokse\" til informationer.`}</p>\n    <h2 {...{\n      \"id\": \"hvor-ska-vi-hen-du\"\n    }}>{`Hvor ska' vi hen, du?`}</h2>\n    <ul>\n      <li parentName=\"ul\">{`Opret en ny tatovør  `}</li>\n      <li parentName=\"ul\">{`Rediger en eksisterende tatovør `}\n        <ul parentName=\"li\">\n          <li parentName=\"ul\">{`Rediger tatovør profil-billede`}</li>\n          <li parentName=\"ul\">{`Tilføj unikt galleri til tatovør`}</li>\n          <li parentName=\"ul\">{`Rediger instagram link til tatovør`}</li>\n        </ul>\n      </li>\n      <li parentName=\"ul\">{`Slet en tatovør`}<br parentName=\"li\"></br>\n        {`Yderligere påkrævet for at oprette en ny tatovør`}</li>\n      <li parentName=\"ul\">{`Opret en tativær-kontaktform`}</li>\n      <li parentName=\"ul\">{`Opret et instagram feed`}</li>\n    </ul>\n    <p><strong parentName=\"p\">{`Gæstetatovør`}</strong></p>\n    <ul>\n      <li parentName=\"ul\">{`Tilføj gæstetatovør`}</li>\n      <li parentName=\"ul\">{`Ændrer en eksisterende tatovør til gæstetatovør`}</li>\n    </ul>\n\n    </MDXLayout>;\n}\n;\nMDXContent.isMDXComponent = true;"}}