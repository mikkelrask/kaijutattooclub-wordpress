t":[]}},{"type":"strong","children":[{"type":"text","value":"Vælg udvalgt billede","position":{"start":{"line":32,"column":104,"offset":2841},"end":{"line":32,"column":124,"offset":2861},"indent":[]}}],"position":{"start":{"line":32,"column":102,"offset":2839},"end":{"line":32,"column":126,"offset":2863},"indent":[]}},{"type":"text","value":" nederst til højre. ","position":{"start":{"line":32,"column":126,"offset":2863},"end":{"line":32,"column":146,"offset":2883},"indent":[]}}],"position":{"start":{"line":32,"column":1,"offset":2738},"end":{"line":32,"column":146,"offset":2883},"indent":[]}},{"type":"export","value":"export const _frontmatter = {}","position":{"start":{"line":36,"column":1,"offset":2887},"end":{"line":36,"column":31,"offset":2917},"indent":[]}}],"position":{"start":{"line":1,"column":1,"offset":0},"end":{"line":36,"column":31,"offset":2917}}},"scopeImports":[],"scopeIdentifiers":[],"rawMDXOutput":"/* @jsx mdx */\nimport { mdx } from '@mdx-js/react';\n/* @jsxRuntime classic */\n/* @jsx mdx */\nimport DefaultLayout from \"/home/mr/repos/kaijutattooclub-wordpress/node_modules/gatsby-theme-docz/src/base/Layout.js\"\nexport const _frontmatter = {};\n\nconst layoutProps = {\n  _frontmatter\n};\nconst MDXLayout = DefaultLayout\nexport default function MDXContent({\n  components,\n  ...props\n}) {\n  return <MDXLayout {...layoutProps} {...props} components={components} mdxType=\"MDXLayout\">\n\n\n    <h2 {...{\n      \"id\": \"udvalgt-billede\"\n    }}>{`Udvalgt billede`}</h2>\n    <p><strong parentName=\"p\">{`Udvalgt billede`}</strong>{` er det billede der bliver vist, når man fx deler sit indlæg fx på `}<strong parentName=\"p\">{`Facebook, i messenger, WhatsApp, Twitter/X`}</strong>{` o.l.\n`}<img alt=\"Udvalgt billede, som det ser ud n\\xE5r man deler p\\xE5 facebook.com\" src={require(\"./fb.png\")} /></p>\n    <p>{`Det er også billedet der bliver vist i `}<strong parentName=\"p\"><a parentName=\"strong\" {...{\n          \"href\": \"https://kaijutattooclub.dk/blog\"\n        }}>{`blog`}</a>{`-oversigten`}</strong>{`, og i `}<strong parentName=\"p\">{`toppen af hvert individuelt indlæg`}</strong>{`.  `}</p>\n    <h3 {...{\n      \"id\": \"tilføj-udvalgt-billede\"\n    }}>{`Tilføj udvalgt billede`}</h3>\n    <p>{`For at tilføje et `}<strong parentName=\"p\">{`udvalgt billede`}</strong>{` til dit indlæg, går du til `}<strong parentName=\"p\"><a parentName=\"strong\" {...{\n          \"href\": \"https://kaijutattooclub.dk/wp-admin/edit.php\"\n        }}>{`Alle Indlæg`}</a></strong>{`, åbner dit indlæg og klikker du på `}<strong parentName=\"p\">{`Vælg udvalgt billede`}</strong>{`, i `}<strong parentName=\"p\">{`Indlæg`}</strong>{`-fanen\n`}<img alt=\"Indl\\xE6g -> V\\xE6lg udvalgt billede\" src=\"https://files.gitbook.com/v0/b/gitbook-x-prod.appspot.com/o/spaces%2FWXKhAtvPVaNwhFvTnnQ8%2Fuploads%2FUlu430QKWoMMJtRZV0Vm%2Fimage.png?alt=media&token=8ae1bd6c-91f8-4b6b-bb14-014d67deb237\" /></p>\n    <h3 {...{\n      \"id\": \"dimensioner-for-udvalgt-billede\"\n    }}>{`Dimensioner for udvalgt billede`}</h3>\n    <p>{`For at dit billede egner sig bedst som udvalgt billede skal det gerne have et `}<strong parentName=\"p\">{`16/9 størrelsesforhold`}</strong>{` - fx `}<strong parentName=\"p\">{`1920×1080px`}</strong>{` `}</p>\n    <p>{`Det er af hensyn til at det ikke bliver beskåret uhensigtsmæssigt, når det deles på fx. Facebook eller twitter, der altid viser billedet i præcist det størrelsesforhold. `}</p>\n    <p>{`Det må meget gerne også indeholde noget grafik der underbygger titlen eller tekst der gentager indlæggets titel.\n`}<img alt=\"Brug gerne indl\\xE6ggets titel - udvalgt billede fungerer lidt som et thumbnail p\\xE5 youtube\" src=\"https://kaijutattooclub.dk/wp-content/uploads/2024/12/FARVE.png\" /></p>\n    <h3 {...{\n      \"id\": \"safe-area\"\n    }}>{`Safe area`}</h3>\n    <p>{`Dog skal man have `}<em parentName=\"p\">{`in mente`}</em>{` at på `}<a parentName=\"p\" {...{\n        \"href\": \"http://kaijutattooclub.dk\"\n      }}>{`kaijutattooclub.dk`}</a>{` vises det i en lavere endnu udgave - der vises det i `}<strong parentName=\"p\">{`21/9 bredde/højde forhold`}</strong>{` - dvs. at dit `}<strong parentName=\"p\">{`vigtigste`}</strong>{` indhold af dit `}<strong parentName=\"p\">{`udvalgt billede`}</strong>{`, `}<em parentName=\"p\">{`skal`}</em>{` være synligt i et 21/9 område i midten af dit `}<strong parentName=\"p\">{`16/9 størrelsesforhold billede`}</strong>{`.`}</p>\n    <p><img alt=\"Eksempelfil - billedet skal have den fulde st\\xF8rrelse som her, hvor det vigtige information fra billedet skal vises i det gule safe area\" src=\"https://files.gitbook.com/v0/b/gitbook-x-prod.appspot.com/o/spaces%2FWXKhAtvPVaNwhFvTnnQ8%2Fuploads%2F3WKlqL0wbMgwdJOBoVkh%2FBlog%20Indl%C3%A6g%20Safe%20Area.png?alt=media&token=f327538a-146a-4dad-8348-36d625d1dad9\" /></p>\n    <p>{`Klik her for at downloade `}<a parentName=\"p\" {...{\n        \"href\": \"https://files.gitbook.com/v0/b/gitbook-x-prod.appspot.com/o/spaces%2FWXKhAtvPVaNwhFvTnnQ8%2Fuploads%2F3WKlqL0wbMgwdJOBoVkh%2FBlog%20Indl%C3%A6g%20Safe%20Area.png?alt=media&token=f327538a-146a-4dad-8348-36d625d1dad9\"\n      }}>{`eksempelfilen`}</a>{`, med de optimale dimensioner. Den er lavet transparent, så du kan tilføje den som et ekstra lag i dit redigeringsprogram, og blot skjule det, før eksport.`}</p>\n    <h3 {...{\n      \"id\": \"upload-dit-udvalgte-billede\"\n    }}>{`Upload dit udvalgte billede`}</h3>\n    <p>{`Når du har lavet dit Udvalgte billede, uploader du det, klik på det, og indsæt det efterfølgende med `}<strong parentName=\"p\">{`Vælg udvalgt billede`}</strong>{` nederst til højre. `}</p>\n\n    </MDXLayout>;\n}\n;\nMDXContent.isMDXComponent = true;"}}